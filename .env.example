# Database Configuration
# Cloud SQL connection for Cloud Run (automatic deployment)
# Set these as environment variables in Cloud Run console

# Cloud SQL Unix Socket (primary method for Cloud Run)
DB_UNIX_SOCKET=/cloudsql/static-lens-268201:us-central1:kalrul
DB_USER=root
DB_PASS=your-secure-password
DB_NAME=kalrul

# TCP Connection (alternative or for local development)
# DB_HOST=your-db-host
# DB_USER=root
# DB_PASS=your-password
# DB_NAME=kalrul
# DB_PORT=3306

# Application Configuration
APP_ENV=production
APP_DEBUG=false

# Session Configuration
SESSION_TIMEOUT_MINUTES=15

# Cloud Run Configuration
# PORT is automatically set by Cloud Run, but you can override locally
# PORT=8080

# Local Development with Docker Compose:
# DB_HOST=db
# DB_USER=root
# DB_PASS=localpassword
# DB_NAME=kalrul
# DB_PORT=3306
# APP_ENV=development
# APP_DEBUG=true
